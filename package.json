{
	"name": "ironclad-auth",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@9.15.4",
	"engines": {
		"node": ">=22"
	},
	"dependencies": {
		"@hono/node-server": "^1.14.0",
		"@hono/swagger-ui": "^0.6.1",
		"@hono/zod-openapi": "^1.4.0",
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.45.2",
		"hono": "^4.7.4",
		"jose": "^6.2.3",
		"postgres": "^3.4.9",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@types/node": "^22.13.5",
		"drizzle-kit": "^0.31.10",
		"tsx": "^4.19.2",
		"typescript": "^6.0.3",
		"vitest": "^4.1.6"
