PORT=3000
DATABASE_URL=postgres://ironclad:ironclad@localhost:5432/ironclad_auth

# OIDC provider (required for `pnpm dev` / `pnpm start` — token validation + /v1/whoami)
IDP_ISSUER=https://YOUR_TENANT.auth0.com/
IDP_AUDIENCE=https://your-api-identifier
IDP_JWKS_URI=https://YOUR_TENANT.auth0.com/.well-known/jwks.json

# Optional — mint Ironclad JWTs (`POST /v1/token/exchange`), `GET /v1/userinfo`, and `GET /.well-known/jwks.json`.
# On first boot with these set, an RSA-2048 signing key is generated and stored in Postgres (`signing_keys`) with the private material encrypted using KEY_ENCRYPTION_SECRET.
# Omit all three together to disable minting (default in CI when unset).
# IRONCLAD_ISSUER=https://auth.yourcompany.example/
# IRONCLAD_TOKEN_AUDIENCE=https://your-resource-servers.example/
# KEY_ENCRYPTION_SECRET=your-long-random-secret-at-least-16-chars
ADMIN_EMAILS=superadmin@example.com