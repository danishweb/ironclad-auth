{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"lib": ["ES2022"],
		"types": ["node"],
		"strict": true,
		"skipLibCheck": true,
		"outDir": "dist",
		"rootDir": "src",
		"declaration": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"verbatimModuleSyntax": true,
		"isolatedModules": true
	},
	"include": ["src/**/*.ts"],
	"exclude": [
		"src/**/*.test.ts",
		"src/db/migrate.ts",
		"src/db/seed.ts",
		"src/token/rotate-signing-key.ts"
	]
}
